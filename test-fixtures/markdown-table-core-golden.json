{
  "conversion": [
    {
      "name": "quoted csv to markdown table",
      "input": "Name,Note\nAnna,\"A, B\"\nBob,\"said \"\"hi\"\"\"",
      "lines": [
        "| Name | Note      |",
        "| ---- | --------- |",
        "| Anna | A, B      |",
        "| Bob  | said \"hi\" |"
      ]
    },
    {
      "name": "tsv escapes pipes",
      "input": "Name\tNote\nAnna\tA|B",
      "lines": [
        "| Name | Note |",
        "| ---- | ---- |",
        "| Anna | A\\|B |"
      ]
    },
    {
      "name": "csv preserves escaped pipes and fixes even slash parity",
      "input": "Name,Note\nAnna,a\\|b\nBob,a\\\\|b",
      "lines": [
        "| Name | Note   |",
        "| ---- | ------ |",
        "| Anna | a\\|b   |",
        "| Bob  | a\\\\\\|b |"
      ]
    },
    {
      "name": "tsv delimiter wins when cell commas are more frequent",
      "input": "Name\tNote\nAnna\tone,two,three,four\nBob\tplain",
      "lines": [
        "| Name | Note               |",
        "| ---- | ------------------ |",
        "| Anna | one,two,three,four |",
        "| Bob  | plain              |"
      ]
    },
    {
